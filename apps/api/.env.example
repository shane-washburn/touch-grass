# --- Server ---
PORT=8787
# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGIN=http://localhost:5173

# --- Stats / leaderboard (Upstash Redis) ---
# Create a free database at https://console.upstash.com and copy the REST
# credentials. When unset, stat tracking is a no-op and the leaderboard
# shows zeros.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- LLM provider (provider-agnostic via Vercel AI SDK) ---
# Default provider is Google Gemini. Swap providers by changing AI_PROVIDER
# and supplying the matching key (see src/ai.ts).
AI_PROVIDER=google

# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# (Optional, if you swap providers later)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
